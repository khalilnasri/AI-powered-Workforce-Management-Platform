            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Warnungen vorhanden?": {
      "main": [
        [
          {
            "node": "E-Mail HTML aufbauen",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "E-Mail HTML aufbauen": {
      "main": [
        [
          {
            "node": "E-Mail senden",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "pinData": {},
  "settings": {
    "executionOrder": "v1"
