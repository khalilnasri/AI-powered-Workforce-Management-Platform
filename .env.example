# Kopieren Sie diese Datei nach ".env" im Projektordner (time-stemple-app)
# Die Datei ".env" wird von Git ignoriert.

# --- PostgreSQL (wie früher, optional OHNE Passwort) ---
# USE_SQLITE auskommentieren oder entfernen, wenn Sie PostgreSQL nutzen.

POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=timestemple

# Passwort:
# - Zeile weglassen → Standard-Passwort "postgres" (wie bisher im Code).
# - Leer lassen für lokales "ohne Passwort" (nur wenn PostgreSQL so eingestellt ist):
POSTGRES_PASSWORD=

# Dafür muss PostgreSQL Verbindungen von localhost OHNE Passwort erlauben.
# In pg_hba.conf z. B. für IPv4-local (Pfad je nach Installation, z. B. Datenordner von Postgres):
#   host    all    all    127.0.0.1/32    trust
# Nach Änderung: Dienst "postgresql" neu starten.
# Vorsicht: "trust" nur auf dem eigenen Rechner / nur 127.0.0.1 — nie so im Internet offen!

# --- Alternative: gar kein PostgreSQL ---
# USE_SQLITE=1
# (dann wird backend/data/timestemple_local.db verwendet)

# Optional: JWT für Produktion setzen
# JWT_SECRET_KEY=langer-zufaelliger-string
